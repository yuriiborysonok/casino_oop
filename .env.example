# ==============================================================================
# Casino Platform Environment Variables - Template
# Copy this file to '.env' and fill in your actual private credentials.
#
# DO NOT commit '.env' containing real secrets to Git.
# ==============================================================================

# --- DATABASE CONFIGURATION ---
# Database connection string used by wallet_service
# For running locally on host machine (mapping to docker postgres on port 5435):
DATABASE_URL=postgresql://casino_user:casino_password@localhost:5435/casino_db

# For running inside docker-compose:
# DATABASE_URL=postgresql://casino_user:casino_password@db:5432/casino_db


# --- SECURITY & AUTHENTICATION SECRETS ---
# Secure signing key for signing access and refresh JWT tokens (Backend & API protect)
JWT_SECRET=replace-with-a-highly-secure-cryptographic-random-string-64-chars

# Shared api key used for internal secure routing communications (game_service <-> wallet_service)
INTERNAL_API_KEY=replace-with-a-secure-shared-microservice-access-token


# --- MICROSERVICES ROUTING ---
# Hostname of the wallet microservice (localhost for native OS run, wallet-service for Docker)
WALLET_HOST=localhost


# --- RIGGED ROULETTE / VIP TESTING OPTIONS (OPTIONAL) ---
# Set ROULETTE_BOOST_NUMBER to force landing on a specific number (0-36)
# Set ROULETTE_BOOST_CHANCE to boost landing chance as percentage (0-100)
ROULETTE_BOOST_NUMBER=17
ROULETTE_BOOST_CHANCE=0
